{
  "name": "googlehomekodi",
  "version": "0.0.2",
  "description": "A node express server for relaying google home commands from IFTTT to your Kodi installation.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "lint": "eslint \"**/*.js\" --ignore-pattern node_modules/",
    "test": "mocha --recursive --require should"
  },
  "engines": {
    "node": "^25.0.0"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.6.0",
    "fuse.js": "^7.3.0",
    "remove-accents": "^0.5.0",
    "word-to-numbers": "^1.0.0",
    "youtube-search": "^1.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^10.2.0",
    "globals": "^16.0.0",
    "mocha": "^11.7.5",
    "node-mocks-http": "^1.17.2",
    "should": "^13.2.3"
  },
  "repository": {
    "url": "https://github.com/OmerTu/GoogleHomeKodi"
  },
  "license": "MIT",
  "keywords": [
    "Kodi",
    "Google Home",
    "IFTTT"
  ]
}
